// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ReportType {
  free_summary
  premium_pdf
}

enum ReportStatus {
  sent
  failed
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  birthYear     Int?
  gender        String?
  parentEmail   String?
  profileFilled Boolean   @default(false)
  isPremium     Boolean   @default(false)
  currentStreak Int       @default(0)
  role          String    @default("user")
  status        String    @default("Aktif")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  parent        Parent?
  payments      Payment[]
  subscription  Subscription?
  baseline      Baseline?
  moodLogs      MoodLog[]
  diaries       Diary[]
  quizLogs      QuizLog[]
  insights      Insight[]

  @@unique([email])
  @@map("user")
}

model Parent {
  id               String        @id
  userId           String        @unique
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  email            String
  status           ParentStatus  @default(pending)
  token            String?       @unique
  requestedAt      DateTime      @default(now())
  lastSentAt       DateTime?
  lastReportType   ReportType?
  lastReportStatus ReportStatus?
  expiresAt        DateTime?
  verifiedAt       DateTime?
  rejectedAt       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([status])
  @@index([email])
  @@map("parent")
}

enum ParentStatus {
  pending
  verified
  expired
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Payment {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  grossAmount  Decimal
  status       String
  paymentType  String
  vaNumber     String?
  paidAt       DateTime?
  expiredAt    DateTime?
  createdAt    DateTime      @default(now())

  subscriptions Subscription[]

  @@index([userId])
  @@map("payment")
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentId String
  payment   Payment  @relation(fields: [paymentId], references: [id])
  startedAt DateTime
  expiresAt DateTime
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([paymentId])
  @@map("subscription")
}

model Baseline {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isBeginner        Boolean  @default(true)
  mlConfidenceScore Decimal?
  analyzedAt        DateTime @default(now())

  @@map("baseline")
}

model MoodLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moodScore Int
  note      String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("mood_log")
}

enum Sender {
  USER
  AI
}

model Diary {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime       @db.Date
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())

  messages  DiaryMessage[]

  @@index([userId])
  @@map("diary")
}

model DiaryMessage {
  id         String   @id @default(cuid())
  diaryId    String
  diary      Diary    @relation(fields: [diaryId], references: [id], onDelete: Cascade)
  senderType Sender
  content    String   @db.Text
  createdAt  DateTime @default(now())

  @@index([diaryId])
  @@map("diary_message")
}

enum AgeSegment {
  ANAK
  REMAJA
  MAHASISWA
  DEWASA_MUDA
}

model QuizQuestion {
  id                   String     @id @default(cuid())
  ageSegment           AgeSegment
  category             String
  scenario             String     @db.Text
  optionA              String
  optionB              String
  correctOption        String
  explanationCorrect   String     @db.Text
  explanationIncorrect String     @db.Text
  isActive             Boolean    @default(true)
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  quizLogs             QuizLog[]

  @@index([ageSegment])
  @@map("quiz_question")
}

model QuizLog {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId   String
  question     QuizQuestion @relation(fields: [questionId], references: [id])
  chosenOption String
  isCorrect    Boolean
  createdAt    DateTime     @default(now())

  @@index([userId])
  @@index([questionId])
  @@map("quiz_log")
}

enum Priority {
  TINGGI
  SEDANG
  RENDAH
}

model Insight {
  id               String                  @id @default(cuid())
  userId           String
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  date             DateTime                @db.Date
  averageScore     Decimal
  analysisText     String                  @db.Text
  cognitivePattern String?                 @db.Text
  affirmation      String?                 @db.Text
  createdAt        DateTime                @default(now())

  recommendations  InsightRecommendation[]

  @@index([userId])
  @@map("insight")
}

model InsightRecommendation {
  id         String   @id @default(cuid())
  insightId  String
  insight    Insight  @relation(fields: [insightId], references: [id], onDelete: Cascade)
  priority   Priority
  actionText String   @db.Text

  @@index([insightId])
  @@map("insight_recommendation")
}
